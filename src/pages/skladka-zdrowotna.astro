---
import Layout from '../layouts/Layout.astro';
import { ROK, ZDROWOTNA, PLACA_MINIMALNA } from '../lib/params2026';
const min = ZDROWOTNA.minimalna.toFixed(2).replace('.', ',');
---

<Layout
  title={`Kalkulator składki zdrowotnej ${ROK} — skala, liniowy, ryczałt`}
  description={`Oblicz miesięczną składkę zdrowotną przedsiębiorcy w ${ROK} r.: 9% na skali, 4,9% na liniowym (min. ${min} zł), ryczałt wg progów przychodu. Bez rejestracji.`}
  aktywna="/skladka-zdrowotna/"
>
  <span class="brew">minimalna {ROK}: {min} zł/mies.</span>
  <h1>Składka zdrowotna przedsiębiorcy {ROK}</h1>
  <p style="max-width: 640px; color: var(--atrament-2);">
    Wysokość składki zdrowotnej zależy od formy opodatkowania. Wpisz swój dochód (lub
    przychód na ryczałcie) i porównaj, ile zapłacisz w każdym wariancie.
  </p>

  <div class="kalkulator">
    <div class="progres">
      <div class="progres-bar">
        <div class="progres-fill" id="progressFill"></div>
      </div>
      <p class="progres-tekst" id="progressTekst">Wpisz dochód lub przychód</p>
    </div>

    <form class="formularz" id="frm" autocomplete="off">
      <div class="pole">
        <label for="dochod">Dochód miesięczny (zł) — skala i liniowy</label>
        <input type="number" id="dochod" placeholder="np. 12000" min="0" step="500" inputmode="decimal" />
        <span class="hint">Przychód minus koszty i składki społeczne</span>
      </div>
      <div class="pole">
        <label for="przychod">Przychód roczny (zł) — ryczałt</label>
        <input type="number" id="przychod" placeholder="np. 144000" min="0" step="10000" inputmode="decimal" />
        <span class="hint">Progi: do 60 000 · do 300 000 · powyżej 300 000</span>
      </div>
    </form>

    <div class="pasek-otoczka">
      <div class="pasek" aria-live="polite">
        <div class="pasek-naglowek">
          <span>Składka miesięczna</span>
          <span>{ROK}</span>
        </div>
        <div class="pasek-cialo">
          <table>
            <tbody>
              <tr>
                <td>Skala podatkowa <span class="hint">(9% dochodu)</span></td>
                <td class="mono" id="skala">—</td>
              </tr>
              <tr>
                <td>Podatek liniowy <span class="hint">(4,9% dochodu)</span></td>
                <td class="mono" id="liniowy">—</td>
              </tr>
              <tr class="suma">
                <td>Ryczałt <span class="hint" id="ryczaltProg"></span></td>
                <td class="mono" id="ryczalt">—</td>
              </tr>
            </tbody>
          </table>
          <p class="roznica" id="opis">Wpisz dochód, aby porównać formy.</p>
        </div>
      </div>
    </div>
  </div>

  <section class="tresc">
    <h2>Zasady w {ROK} roku</h2>
    <p>
      Od {ROK} r. skończyła się preferencja z lat poprzednich — minimalna składka
      zdrowotna liczona jest znów od pełnej płacy minimalnej ({PLACA_MINIMALNA} zł), czyli
      wynosi <strong>{min} zł miesięcznie</strong> na skali i liniowym, niezależnie od
      dochodu (nawet przy stracie).
    </p>
    <ul>
      <li><strong>Skala podatkowa:</strong> 9% dochodu, bez możliwości odliczenia.</li>
      <li>
        <strong>Podatek liniowy:</strong> 4,9% dochodu; zapłaconą składkę można odliczyć
        od dochodu do limitu {ZDROWOTNA.liniowyLimitOdliczenia.toLocaleString('pl-PL')} zł rocznie.
      </li>
      <li>
        <strong>Ryczałt:</strong> stała kwota zależna od progu przychodów w roku
        składkowym (1.02.{ROK}–31.01.{ROK + 1}):
        {ZDROWOTNA.ryczalt.do60k.toFixed(2).replace('.', ',')} zł (do 60 tys.),
        {ZDROWOTNA.ryczalt.do300k.toFixed(2).replace('.', ',')} zł (do 300 tys.),
        {ZDROWOTNA.ryczalt.ponad300k.toFixed(2).replace('.', ',')} zł (powyżej).
        Od przychodu odliczysz 50% zapłaconych składek.
      </li>
    </ul>
    <h2>Rozliczenie roczne</h2>
    <p>
      Składka zdrowotna podlega rozliczeniu rocznemu (do 20 maja kolejnego roku). Jeśli w
      trakcie roku płaciłeś od zaniżonej podstawy — dopłacisz; jeśli od zawyżonej —
      dostaniesz zwrot. Na ryczałcie przekroczenie progu przychodów w trakcie roku
      oznacza dopłatę wstecz za wszystkie miesiące.
    </p>
    <div class="zastrzezenie">
      Kalkulator poglądowy — stawki na {ROK} r. (rok składkowy dla ryczałtu:
      luty {ROK} – styczeń {ROK + 1}). Za styczeń {ROK} obowiązywała jeszcze niższa
      minimalna (314,96 zł). Nie stanowi porady podatkowej.
    </div>
    <p>
      Więcej o zasadach i przykładach liczbowych: <a href="/blog/skladka-zdrowotna-2026-przewodnik/">Składka zdrowotna przedsiębiorcy {ROK} — pełny przewodnik</a>.
    </p>
  </section>
</Layout>

<script>
  import { zlGr } from '../lib/podatki';
  import { ZDROWOTNA } from '../lib/params2026';

  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;

  function aktualizujProgress() {
    const dochod = Math.max(0, Number($('dochod').value) || 0);
    const przychodRok = Math.max(0, Number($('przychod').value) || 0);

    let krok = 0;
    if (dochod > 0) krok++;
    if (przychodRok > 0) krok++;

    const procent = (krok / 2) * 100;
    const teksty = [
      'Wpisz dochód lub przychód',
      'Dodaj przychód roczny',
      '✓ Gotowe — porównaj składki',
    ];

    const fillEl = document.getElementById('progressFill') as HTMLElement;
    const tekstEl = document.getElementById('progressTekst') as HTMLElement;
    if (fillEl) fillEl.style.transform = `scaleX(${procent / 100})`;
    if (tekstEl) tekstEl.textContent = teksty[krok];
  }

  function przelicz() {
    aktualizujProgress();
    const dochod = Math.max(0, Number($('dochod').value) || 0);
    const przychodRok = Math.max(0, Number($('przychod').value) || 0);

    if (dochod > 0) {
      $('skala').textContent = zlGr(Math.max(dochod * ZDROWOTNA.skalaProc, ZDROWOTNA.minimalna));
      $('liniowy').textContent = zlGr(Math.max(dochod * ZDROWOTNA.liniowyProc, ZDROWOTNA.minimalna));
    } else {
      $('skala').textContent = '—';
      $('liniowy').textContent = '—';
    }

    if (przychodRok > 0) {
      const ryczalt =
        przychodRok <= 60000
          ? ZDROWOTNA.ryczalt.do60k
          : przychodRok <= 300000
            ? ZDROWOTNA.ryczalt.do300k
            : ZDROWOTNA.ryczalt.ponad300k;
      const prog =
        przychodRok <= 60000 ? 'próg do 60 tys.' : przychodRok <= 300000 ? 'próg do 300 tys.' : 'próg powyżej 300 tys.';
      $('ryczalt').textContent = zlGr(ryczalt);
      $('ryczaltProg').textContent = `(${prog})`;
    } else {
      $('ryczalt').textContent = '—';
      $('ryczaltProg').textContent = '';
    }

    if (dochod <= 0 || przychodRok <= 0) {
      $('opis').textContent = 'Wpisz dochód i przychód, aby porównać formy.';
      return;
    }

    const skala = Math.max(dochod * ZDROWOTNA.skalaProc, ZDROWOTNA.minimalna);
    const liniowy = Math.max(dochod * ZDROWOTNA.liniowyProc, ZDROWOTNA.minimalna);
    const ryczalt =
      przychodRok <= 60000
        ? ZDROWOTNA.ryczalt.do60k
        : przychodRok <= 300000
          ? ZDROWOTNA.ryczalt.do300k
          : ZDROWOTNA.ryczalt.ponad300k;

    const najnizsza = Math.min(skala, liniowy, ryczalt);
    const forma = najnizsza === ryczalt ? 'ryczałcie' : najnizsza === liniowy ? 'podatku liniowym' : 'skali';
    $('opis').innerHTML =
      `Przy tych kwotach najniższą składkę zapłacisz na <b>${forma}</b>: <b>${zlGr(najnizsza)}</b>/mies. ` +
      `Pamiętaj: o opłacalności formy decyduje łącznie podatek + składka, nie sama składka.`;
  }

  document.getElementById('frm')!.addEventListener('input', przelicz);
  przelicz();
</script>
