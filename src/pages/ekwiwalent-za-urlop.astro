---
import Layout from '../layouts/Layout.astro';
import { ROK, WSPOLCZYNNIK_URLOPOWY } from '../lib/params2026';
const wsp = WSPOLCZYNNIK_URLOPOWY.toString().replace('.', ',');
---

<Layout
  title={`Kalkulator ekwiwalentu za urlop ${ROK} — współczynnik ${wsp}`}
  description={`Oblicz ekwiwalent za niewykorzystany urlop wypoczynkowy w ${ROK} r. Współczynnik ${wsp}, wymiar etatu, kwota brutto — prosty kalkulator bez rejestracji.`}
  aktywna="/ekwiwalent-za-urlop/"
>
  <span class="brew">współczynnik {ROK}: {wsp}</span>
  <h1>Ekwiwalent za niewykorzystany urlop</h1>
  <p style="max-width: 640px; color: var(--atrament-2);">
    Kończysz pracę i został Ci urlop? Pracodawca musi wypłacić ekwiwalent pieniężny.
    Wpisz swoje wynagrodzenie i liczbę dni — zobaczysz kwotę brutto z pełnym wyliczeniem.
  </p>

  <div class="kalkulator">
    <div class="progres">
      <div class="progres-bar">
        <div class="progres-fill" id="progressFill"></div>
      </div>
      <p class="progres-tekst" id="progressTekst">Wpisz wynagrodzenie i dni</p>
    </div>

    <form class="formularz" id="frm" autocomplete="off">
      <div class="pole">
        <label for="podstawa">Wynagrodzenie miesięczne brutto (zł)</label>
        <input type="number" id="podstawa" value="8000" min="0" step="100" inputmode="decimal" />
        <span class="hint">
          Stałe składniki z miesiąca nabycia prawa + średnia zmiennych (premie, nadgodziny)
          z 3 poprzednich miesięcy
        </span>
      </div>

      <div class="pole-wiersz">
        <div class="pole">
          <label for="dni">Dni niewykorzystanego urlopu</label>
          <input type="number" id="dni" value="10" min="0" max="70" step="0.5" inputmode="decimal" />
        </div>
        <div class="pole">
          <label for="etat">Wymiar etatu</label>
          <select id="etat">
            <option value="1" selected>Pełny etat</option>
            <option value="0.75">3/4 etatu</option>
            <option value="0.5">1/2 etatu</option>
            <option value="0.333333">1/3 etatu</option>
            <option value="0.25">1/4 etatu</option>
          </select>
        </div>
      </div>
    </form>

    <div class="pasek-otoczka">
      <div class="pasek" aria-live="polite">
        <div class="pasek-naglowek">
          <span>Ekwiwalent</span>
          <span>{ROK}</span>
        </div>
        <div class="pasek-cialo">
          <p class="wynik-glowny">
            <span class="etykieta">Do wypłaty brutto</span>
            <span class="kwota" id="wynik">—</span>
          </p>
          <table>
            <tbody>
              <tr>
                <td>Współczynnik (× etat)</td>
                <td class="mono" id="wspolczynnik">—</td>
              </tr>
              <tr>
                <td>Stawka za 1 dzień</td>
                <td class="mono" id="dzienna">—</td>
              </tr>
              <tr>
                <td>Stawka za 1 godzinę</td>
                <td class="mono" id="godzinowa">—</td>
              </tr>
              <tr class="suma">
                <td>Godziny urlopu</td>
                <td class="mono" id="godziny">—</td>
              </tr>
            </tbody>
          </table>
          <p class="roznica" id="opis">Wpisz dane, aby zobaczyć wyliczenie.</p>
        </div>
      </div>
    </div>
  </div>

  <section class="tresc">
    <h2>Jak liczy się ekwiwalent w {ROK} roku?</h2>
    <p>
      Współczynnik urlopowy na {ROK} r. wynosi <strong>{wsp}</strong> — to przeciętna
      miesięczna liczba dni roboczych: [365 − (52 niedziele + 10 świąt + 52 dni wolne)] ÷ 12.
      Twoje wynagrodzenie dzielimy przez współczynnik (proporcjonalny do etatu), wynik
      przez 8 godzin normy dobowej, a stawkę godzinową mnożymy przez godziny
      niewykorzystanego urlopu (1 dzień = 8 godzin).
    </p>
    <h2>Kiedy przysługuje ekwiwalent?</h2>
    <p>
      Ekwiwalent przysługuje wyłącznie przy <strong>rozwiązaniu lub wygaśnięciu umowy o
      pracę</strong> — w trakcie zatrudnienia pracodawca nie może „wykupić” urlopu.
      Wypłata następuje w ostatnim dniu zatrudnienia. Od kwoty brutto pracodawca potrąca
      składki ZUS i zaliczkę PIT jak od zwykłego wynagrodzenia.
    </p>
    <div class="zastrzezenie">
      Kalkulator pokazuje kwotę brutto wg zasad rozporządzenia urlopowego. W przypadku
      zmiennych składników wynagrodzenia podstawę ustala się z 3 (lub 12) miesięcy — w
      razie wątpliwości skonsultuj się z działem kadr. Stawki na {ROK} r.
    </div>
    <p>
      Wzór krok po kroku i przykłady liczbowe: <a href="/blog/ekwiwalent-za-urlop-jak-liczyc/">Ekwiwalent za niewykorzystany urlop — jak liczyć i kiedy się należy</a>.
    </p>
  </section>
</Layout>

<script>
  import { ekwiwalent, zlGr } from '../lib/podatki';

  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;

  function aktualizujProgress() {
    const podstawa = Math.max(0, Number($('podstawa').value) || 0);
    const dni = Math.max(0, Number($('dni').value) || 0);
    const etat = Number(($('etat') as unknown as HTMLSelectElement).value);

    let krok = 0;
    if (podstawa > 0) krok++;
    if (dni > 0) krok++;
    if (etat > 0) krok++;

    const procent = (krok / 3) * 100;
    const teksty = [
      'Wpisz wynagrodzenie i dni',
      'Wpisz liczbę dni urlopu',
      'Wybierz wymiar etatu',
      '✓ Gotowe — zobacz ekwiwalent',
    ];

    const fillEl = document.getElementById('progressFill') as HTMLElement;
    const tekstEl = document.getElementById('progressTekst') as HTMLElement;
    if (fillEl) fillEl.style.transform = `scaleX(${procent / 100})`;
    if (tekstEl) tekstEl.textContent = teksty[krok];
  }

  function przelicz() {
    aktualizujProgress();
    const podstawa = Math.max(0, Number($('podstawa').value) || 0);
    const dni = Math.max(0, Number($('dni').value) || 0);
    const etat = Number(($('etat') as unknown as HTMLSelectElement).value);

    const w = ekwiwalent(podstawa, dni, etat);

    $('wynik').textContent = zlGr(w.ekwiwalentBrutto);
    $('wspolczynnik').textContent = w.wspolczynnik.toFixed(2).replace('.', ',');
    $('dzienna').textContent = zlGr(w.stawkaDzienna);
    $('godzinowa').textContent = zlGr(w.stawkaGodzinowa);
    $('godziny').textContent = `${w.godzinyUrlopu} h`;

    $('opis').innerHTML =
      dni > 0
        ? `Za <b>${dni}</b> dni urlopu pracodawca wypłaci <b>${zlGr(w.ekwiwalentBrutto)}</b> brutto.`
        : 'Wpisz liczbę dni urlopu.';
  }

  document.getElementById('frm')!.addEventListener('input', przelicz);
  przelicz();
</script>
