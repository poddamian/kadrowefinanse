---
import Layout from '../../layouts/Layout.astro';
import { ROK } from '../../lib/params2026';

const artykuly = [
  {
    url: '/blog/b2b-czy-umowa-o-prace-2026/',
    tytul: 'B2B czy umowa o pracę — co się bardziej opłaca w 2026 roku?',
    opis:
      'Porównanie netto z etatu i z B2B przy 4 poziomach zarobków, liczone tym samym silnikiem co kalkulator. Od jakiej kwoty B2B zaczyna się opłacać.',
    brew: 'case study · 4 poziomy zarobków',
  },
  {
    url: '/blog/skladka-zdrowotna-2026-przewodnik/',
    tytul: 'Składka zdrowotna przedsiębiorcy 2026 — pełny przewodnik po zmianach',
    opis:
      'Ile wynosi składka zdrowotna na skali, liniowym i ryczałcie w 2026 r. — stawki, minimalna składka, limity odliczeń i przykład liczbowy.',
    brew: 'przewodnik · skala, liniowy, ryczałt',
  },
  {
    url: '/blog/nadplata-kredytu-hipotecznego-okres-czy-rata/',
    tytul: 'Nadpłata kredytu hipotecznego — skrócić okres czy zmniejszyć ratę?',
    opis:
      'Porównanie dwóch trybów nadpłaty na przykładzie 400 000 zł: ile realnie oszczędzasz przy skróceniu okresu, a ile przy zmniejszeniu raty.',
    brew: 'case study · 400 000 zł, 25 lat',
  },
  {
    url: '/blog/ekwiwalent-za-urlop-jak-liczyc/',
    tytul: 'Ekwiwalent za niewykorzystany urlop — jak liczyć i kiedy się należy',
    opis:
      'Wzór na ekwiwalent krok po kroku, przykłady liczbowe dla różnej liczby dni i wymiaru etatu oraz zasady wypłaty przy rozwiązaniu umowy.',
    brew: 'poradnik · wzór krok po kroku',
  },
  {
    url: '/blog/ryczalt-czy-liniowy-2026/',
    tytul: 'Ryczałt czy podatek liniowy na B2B — co wybrać w 2026 roku?',
    opis:
      'Porównanie na przykładach przy 8, 12 i 20 tys. zł przychodu. Kiedy ryczałt się opłaca, a kiedy lepszy jest liniowy.',
    brew: 'case study · 3 poziomy przychodu',
  },
  {
    url: '/blog/jak-obnizyc-skladke-zdrowotna/',
    tytul: 'Jak obniżyć składkę zdrowotną na działalności gospodarczej',
    opis:
      'Legalne sposoby: wpływ kosztów firmowych, wybór formy opodatkowania, odliczenia — z przykładami liczbowymi.',
    brew: 'poradnik · legalne sposoby',
  },
  {
    url: '/blog/rekomendacja-s-wczesniejsza-splata-kredytu/',
    tytul: 'Rekomendacja S i wcześniejsza spłata kredytu — co musisz wiedzieć',
    opis:
      'Kiedy bank może pobrać rekompensatę za wcześniejszą spłatę, ile może wynosić i czy nadpłata mimo to się opłaca.',
    brew: 'case study · rekompensata vs oszczędność',
  },
  {
    url: '/blog/urlop-proporcjonalny-na-zadanie-zalegly/',
    tytul: 'Urlop na żądanie, zaległy, proporcjonalny — kompendium',
    opis:
      'Ile dni urlopu na żądanie, do kiedy wykorzystać zaległy i jak liczy się urlop proporcjonalny przy zmianie pracy w trakcie roku.',
    brew: 'kompendium · 3 rodzaje urlopu',
  },
  {
    url: '/blog/preferencyjny-zus-ulga-na-start/',
    tytul: 'Preferencyjny ZUS i ulga na start — ile trwają i co dalej?',
    opis:
      'Ulga na start, preferencyjny ZUS, duży ZUS — ile trwa każdy etap i o ile spada netto przy przejściu na kolejny, na przykładzie liczbowym.',
    brew: 'case study · 3 etapy oskładkowania',
  },
  {
    url: '/blog/maly-zus-plus-2026/',
    tytul: 'Mały ZUS Plus 2026 — kto może skorzystać i ile zaoszczędzi',
    opis:
      'Warunki ulgi, nowe zasady 36 miesięcy w każdym 60-miesięcznym okresie od 2026 r. i realne oszczędności na składkach przy 3 poziomach dochodu.',
    brew: 'case study · nowe zasady 2026',
  },
];
---

<Layout
  title={`Blog — poradniki finansowo-kadrowe ${ROK}`}
  description="Artykuły o podatkach, ZUS, składce zdrowotnej i kredytach — wyliczenia na przykładach, oparte na tych samych wzorach co nasze kalkulatory."
>
  <h1>Blog</h1>
  <p style="max-width: 640px; color: var(--atrament-2);">
    Poradniki i wyliczenia na przykładach — o podatkach, ZUS, składce zdrowotnej i kredytach.
    Każdy artykuł opiera się na tych samych wzorach co nasze kalkulatory.
  </p>

  <div class="siatka-kart">
    {
      artykuly.map((a) => (
        <a href={a.url} class="karta-narzedzia">
          <span class="brew">{a.brew}</span>
          <h3>{a.tytul}</h3>
          <p>{a.opis}</p>
        </a>
      ))
    }
  </div>
</Layout>
