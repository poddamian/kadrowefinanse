---
import Layout from '../layouts/Layout.astro';
import { ROK } from '../lib/params2026';
---

<Layout
  title="Kalkulator nadpłaty kredytu hipotecznego — ile oszczędzisz?"
  description="Policz, ile odsetek zaoszczędzisz i o ile skrócisz kredyt hipoteczny nadpłacając co miesiąc lub jednorazowo. Symulacja miesiąc po miesiącu, bez rejestracji."
  aktywna="/nadplata-kredytu/"
>
  <span class="brew">symulacja miesiąc po miesiącu</span>
  <h1>Nadpłata kredytu — ile naprawdę oszczędzisz?</h1>
  <p style="max-width: 640px; color: var(--atrament-2);">
    Wpisz parametry swojego kredytu i planowaną nadpłatę. Kalkulator zasymuluje spłatę
    miesiąc po miesiącu i pokaże oszczędność na odsetkach oraz skrócenie okresu.
  </p>

  <div class="kalkulator">
    <div class="progres">
      <div class="progres-bar">
        <div class="progres-fill" id="progressFill"></div>
      </div>
      <p class="progres-tekst" id="progressTekst">Wpisz parametry kredytu</p>
    </div>

    <form class="formularz" id="frm" autocomplete="off">
      <div class="pole-wiersz">
        <div class="pole">
          <label for="kapital">Pozostały kapitał (zł)</label>
          <input type="number" id="kapital" value="400000" min="0" step="1000" inputmode="decimal" />
        </div>
        <div class="pole">
          <label for="oproc">Oprocentowanie (% rocznie)</label>
          <input type="number" id="oproc" value="7.20" min="0" max="30" step="0.01" inputmode="decimal" />
          <span class="hint">Marża + WIBOR/WIRON albo stopa stała</span>
        </div>
      </div>

      <div class="pole-wiersz">
        <div class="pole">
          <label for="lata">Pozostały okres (lata)</label>
          <input type="number" id="lata" value="25" min="1" max="40" step="1" inputmode="numeric" />
        </div>
        <div class="pole">
          <label for="nadplataMies">Nadpłata miesięczna (zł)</label>
          <input type="number" id="nadplataMies" value="500" min="0" step="100" inputmode="decimal" />
        </div>
      </div>

      <div class="pole">
        <label for="nadplataJedn">Nadpłata jednorazowa na start (zł)</label>
        <input type="number" id="nadplataJedn" value="0" min="0" step="1000" inputmode="decimal" />
      </div>

      <div class="pole">
        <label>Co robi bank po nadpłacie?</label>
        <div class="segmenty" role="radiogroup" aria-label="Tryb nadpłaty">
          <label><input type="radio" name="tryb" value="okres" checked /> Skraca okres</label>
          <label><input type="radio" name="tryb" value="rata" /> Zmniejsza ratę</label>
        </div>
        <span class="hint">Skrócenie okresu daje zawsze większą oszczędność na odsetkach.</span>
      </div>
    </form>

    <div class="pasek-otoczka">
      <div class="pasek" aria-live="polite">
        <div class="pasek-naglowek">
          <span>Wynik symulacji</span>
          <span>{ROK}</span>
        </div>
        <div class="pasek-cialo">
          <p class="wynik-glowny">
            <span class="etykieta">Oszczędność na odsetkach</span>
            <span class="kwota" id="oszczednosc">—</span>
          </p>
          <table>
            <tbody>
              <tr>
                <td>Rata bez nadpłat</td>
                <td class="mono" id="rata">—</td>
              </tr>
              <tr>
                <td>Odsetki bez nadpłat</td>
                <td class="mono" id="odsetkiBez">—</td>
              </tr>
              <tr>
                <td>Odsetki z nadpłatą</td>
                <td class="mono" id="odsetkiZ">—</td>
              </tr>
              <tr>
                <td id="wierszOkresEtykieta">Spłacisz szybciej o</td>
                <td class="mono" id="skrocenie">—</td>
              </tr>
              <tr class="suma">
                <td>Koniec spłaty</td>
                <td class="mono" id="koniec">—</td>
              </tr>
            </tbody>
          </table>
          <p class="roznica" id="podsumowanie">Wpisz dane kredytu, aby zobaczyć wynik.</p>
        </div>
      </div>
    </div>
  </div>

  <section class="tresc">
    <h2>Skrócenie okresu czy mniejsza rata?</h2>
    <p>
      Przy tej samej nadpłacie <strong>skrócenie okresu</strong> daje zawsze większą
      oszczędność — kapitał znika szybciej, więc bank nalicza odsetki krócej.
      <strong>Zmniejszenie raty</strong> daje za to niższe stałe obciążenie budżetu i
      bufor bezpieczeństwa. Jeśli Twoim celem jest minimalny koszt kredytu, wybieraj
      skrócenie okresu; jeśli płynność — mniejszą ratę.
    </p>
    <h2>Czy bank może pobrać prowizję za nadpłatę?</h2>
    <p>
      Dla kredytów hipotecznych zaciągniętych po 22 lipca 2017 r. (ustawa o kredycie
      hipotecznym) bank może pobierać rekompensatę za nadpłatę tylko w ciągu pierwszych
      36 miesięcy przy oprocentowaniu zmiennym. Po 3 latach nadpłata jest bezpłatna —
      sprawdź swoją umowę.
    </p>
    <div class="zastrzezenie">
      Symulacja zakłada stałe oprocentowanie przez cały okres i raty równe (annuitetowe).
      Rzeczywiste oprocentowanie zmienne (WIBOR/WIRON) będzie się zmieniać, więc traktuj
      wynik jako przybliżenie. To nie jest porada finansowa.
    </div>
  </section>
</Layout>

<script>
  import { symulujNadplate, zlGr, zl } from '../lib/podatki';

  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;

  function okresSlownie(mies: number): string {
    const lata = Math.floor(mies / 12);
    const m = mies % 12;
    const czesci = [];
    if (lata > 0) czesci.push(`${lata} ${lata === 1 ? 'rok' : lata < 5 ? 'lata' : 'lat'}`);
    if (m > 0) czesci.push(`${m} mies.`);
    return czesci.join(' i ') || '0 mies.';
  }

  function aktualizujProgress() {
    const kapital = Math.max(0, Number($('kapital').value) || 0);
    const oproc = Math.max(0, Number($('oproc').value) || 0);
    const lata = Math.max(0, Number($('lata').value) || 0);
    const nadplataMies = Math.max(0, Number($('nadplataMies').value) || 0);
    const nadplataJednorazowa = Math.max(0, Number($('nadplataJedn').value) || 0);

    let krok = 0;
    if (kapital > 0) krok++;
    if (oproc > 0) krok++;
    if (lata > 0) krok++;
    if (nadplataMies > 0 || nadplataJednorazowa > 0) krok++;

    const procent = (krok / 4) * 100;
    const teksty = [
      'Wpisz parametry kredytu',
      'Wpisz oprocentowanie',
      'Wpisz okres spłaty',
      'Dodaj nadpłatę',
      '✓ Gotowe — zobacz oszczędność',
    ];

    const fillEl = document.getElementById('progressFill') as HTMLElement;
    const tekstEl = document.getElementById('progressTekst') as HTMLElement;
    if (fillEl) fillEl.style.transform = `scaleX(${procent / 100})`;
    if (tekstEl) tekstEl.textContent = teksty[krok];
  }

  function przelicz() {
    aktualizujProgress();
    const kapital = Math.max(0, Number($('kapital').value) || 0);
    const oproc = Math.max(0, Number($('oproc').value) || 0) / 100;
    const okresMies = Math.max(1, Math.round(Number($('lata').value) || 1) * 12);
    const nadplataMies = Math.max(0, Number($('nadplataMies').value) || 0);
    const nadplataJednorazowa = Math.max(0, Number($('nadplataJedn').value) || 0);
    const tryb = (document.querySelector('input[name="tryb"]:checked') as HTMLInputElement)
      .value as 'okres' | 'rata';

    const w = symulujNadplate({
      kapital,
      oprocentowanie: oproc,
      okresMies,
      nadplataMies,
      nadplataJednorazowa,
      tryb,
    });

    $('oszczednosc').textContent = zl(w.oszczednosc);
    $('rata').textContent = zlGr(w.rataBazowa);
    $('odsetkiBez').textContent = zl(w.odsetkiBez);
    $('odsetkiZ').textContent = zl(w.odsetkiZ);

    if (tryb === 'okres') {
      $('wierszOkresEtykieta').textContent = 'Spłacisz szybciej o';
      $('skrocenie').textContent = okresSlownie(w.skrocenieMies);
    } else {
      $('wierszOkresEtykieta').textContent = 'Nowa rata po nadpłacie';
      $('skrocenie').textContent = zlGr(w.rataPoNadplacie);
    }

    const dzis = new Date();
    dzis.setMonth(dzis.getMonth() + w.okresZMies);
    $('koniec').textContent = dzis.toLocaleDateString('pl-PL', {
      month: 'long',
      year: 'numeric',
    });

    const el = $('podsumowanie');
    if (nadplataMies === 0 && nadplataJednorazowa === 0) {
      el.innerHTML = 'Dodaj nadpłatę, aby zobaczyć oszczędność.';
    } else if (tryb === 'okres') {
      el.innerHTML = `Nadpłacając, oszczędzasz <b>${zl(w.oszczednosc)}</b> i kończysz kredyt <b>${okresSlownie(w.skrocenieMies)}</b> wcześniej.`;
    } else {
      el.innerHTML = `Nadpłacając, oszczędzasz <b>${zl(w.oszczednosc)}</b> na odsetkach przy zachowaniu okresu spłaty.`;
    }
  }

  document.getElementById('frm')!.addEventListener('input', przelicz);
  przelicz();
</script>
