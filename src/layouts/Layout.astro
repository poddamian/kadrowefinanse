---
import '@fontsource-variable/manrope';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/700.css';
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description: string;
  /** Ścieżka bieżącej strony do zaznaczenia w menu, np. "/b2b-czy-uop/" */
  aktywna?: string;
}

const { title, description, aktywna = '' } = Astro.props;

const narzedzia = [
  { url: '/b2b-czy-uop/', nazwa: 'B2B czy UoP' },
  { url: '/nadplata-kredytu/', nazwa: 'Nadpłata kredytu' },
  { url: '/ekwiwalent-za-urlop/', nazwa: 'Ekwiwalent za urlop' },
  { url: '/skladka-zdrowotna/', nazwa: 'Składka zdrowotna' },
];
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pl_PL" />
  </head>
  <body>
    <header class="naglowek">
      <div class="kontener naglowek-wiersz">
        <a href="/" class="logo">
          <svg class="logo-ikona" viewBox="0 0 128 128" aria-hidden="true" focusable="false">
            <path d="M50.4 78.5a75.1 75.1 0 0 0-28.5 6.9l24.2-65.7c.7-2 1.9-3.2 3.4-3.2h29c1.5 0 2.7 1.2 3.4 3.2l24.2 65.7s-11.6-7-28.5-7L67 45.5c-.4-1.7-1.6-2.8-2.9-2.8-1.3 0-2.5 1.1-2.9 2.7L50.4 78.5Zm-1.1 28.2Zm-4.2-20.2c-2 6.6-.6 15.8 4.2 20.2a17.5 17.5 0 0 1 .2-.7 5.5 5.5 0 0 1 5.7-4.5c2.8.1 4.3 1.5 4.7 4.7.2 1.1.2 2.3.2 3.5v.4c0 2.7.7 5.2 2.2 7.4a13 13 0 0 0 5.7 4.9v-.3l-.2-.3c-1.8-5.6-.5-9.5 4.4-12.8l1.5-1a73 73 0 0 0 3.2-2.2 16 16 0 0 0 6.8-11.4c.3-2 .1-4-.6-6l-.8.6-1.6 1a37 37 0 0 1-22.4 2.7c-5-.7-9.7-2-13.2-6.2Z" />
          </svg>
          Kadrowe <b>Finanse</b>
        </a>
        <button class="menu-toggle" aria-label="Przełącz menu" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <nav class="menu" aria-label="Kalkulatory" id="menu-mobile">
          {
            narzedzia.map((n) => (
              <a href={n.url} aria-current={aktywna === n.url ? 'page' : undefined}>
                {n.nazwa}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <script>
      const menuToggle = document.querySelector('.menu-toggle');
      const menu = document.getElementById('menu-mobile');

      menuToggle?.addEventListener('click', () => {
        const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', String(!isExpanded));
        menu?.classList.toggle('aktywne');
      });

      document.addEventListener('click', (e) => {
        if (!e.target.closest('.naglowek')) {
          menuToggle?.setAttribute('aria-expanded', 'false');
          menu?.classList.remove('aktywne');
        }
      });
    </script>

    <main class="kontener">
      <slot />
    </main>

    <footer class="stopka">
      <div class="kontener">
        <div class="stopka-linki">
          <a href="/blog/">Blog</a>
          <a href="/o-nas/">O nas</a>
          <a href="/kontakt/">Kontakt</a>
          <a href="/polityka-prywatnosci/">Polityka prywatności</a>
          <a href="/regulamin/">Regulamin</a>
          <a href="#" id="stopka-cookie-ustawienia">Ustawienia cookies</a>
        </div>
        <p>
          © {new Date().getFullYear()} Kadrowe Finanse. Kalkulatory mają charakter poglądowy i nie
          stanowią porady podatkowej, prawnej ani finansowej. Wszystkie obliczenia wykonują
          się w Twojej przeglądarce — nie wysyłamy żadnych danych na serwer.
        </p>
      </div>
    </footer>

    <CookieConsent />
  </body>
</html>
